<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title><%= mantenimiento._id ? 'Editar' : 'Nuevo' %> Mantenimiento</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <a href="/" class="home-link">🏠 Inicio</a>
  <button class="theme-toggle" id="theme-toggle">🌙</button>
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success">
      <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
      <%= message || 'Operación exitosa' %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
      <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 9l-9 7z" fill="none"/><path d="M13.59 7.58L9 12.17 6.41 9.59 5 11l4 4 8-8z"/></svg>
      <%= message || 'Error en la operación' %>
    </div>
  <% } %>
  <h1><%= mantenimiento._id ? 'Editar' : 'Crear' %> Mantenimiento</h1>
  <form action="<%= mantenimiento._id ? '/api/mantenimientos/' + mantenimiento._id + '?_method=PUT' : '/api/mantenimientos' %>" method="post">
    <label>Activo:
      <select name="activo_id" required>
        <option value="">--</option>
        <% activos.forEach(a => { %>
          <option value="<%= a._id %>" <%= mantenimiento.activo_id && mantenimiento.activo_id.toString() === a._id.toString() ? 'selected' : '' %>><%= a.serial_unico %></option>
        <% }) %>
      </select>
    </label><br>
    <label>Técnico encargado: <input name="tecnico_encargado" value="<%= mantenimiento.tecnico_encargado || '' %>" required></label><br>
    <label>Fecha servicio: <input type="date" name="fecha_servicio" value="<%= mantenimiento.fecha_servicio ? mantenimiento.fecha_servicio.toISOString().split('T')[0] : '' %>"></label><br>
    <label>Costo: <input type="number" step="0.01" name="costo" value="<%= mantenimiento.costo || '' %>" required></label><br>
    <button type="submit">Guardar</button>
  </form>
  <a href="/mantenimientos/vista">Cancelar</a>
  <script>
    const toggle = document.getElementById('theme-toggle');
    const body = document.body;

    if (localStorage.getItem('theme') === 'dark') {
      body.classList.add('dark');
      toggle.textContent = '☀️';
    }

    toggle.addEventListener('click', () => {
      body.classList.toggle('dark');
      const isDark = body.classList.contains('dark');
      toggle.textContent = isDark ? '☀️' : '🌙';
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  </script>
</body>
</html>