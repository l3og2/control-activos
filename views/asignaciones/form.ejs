<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title><%= asignacion._id ? 'Editar' : 'Nueva' %> Asignación</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <a href="/" class="home-link">🏠 Inicio</a>
  <button class="theme-toggle" id="theme-toggle">🌙</button>
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success">
      <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
      <%= message || 'Operación exitosa' %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
      <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 9l-9 7z" fill="none"/><path d="M13.59 7.58L9 12.17 6.41 9.59 5 11l4 4 8-8z"/></svg>
      <%= message || 'Error en la operación' %>
    </div>
  <% } %>
  <h1><%= asignacion._id ? 'Editar' : 'Crear' %> Asignación</h1>
  <form action="<%= asignacion._id ? '/api/asignaciones/' + asignacion._id + '?_method=PUT' : '/api/asignaciones' %>" method="post">
    <label>Fecha entrega: <input type="date" name="fecha_entrega" value="<%= asignacion.fecha_entrega ? asignacion.fecha_entrega.toISOString().split('T')[0] : '' %>" required></label><br>
    <label>Activo:
      <select name="activo_id" required>
        <option value="">--</option>
        <% activos.forEach(a => { %>
          <option value="<%= a._id %>" <%= asignacion.activo_id && asignacion.activo_id.toString() === a._id.toString() ? 'selected' : '' %>><%= a.serial_unico %></option>
        <% }) %>
      </select>
    </label><br>
    <label>Empleado:
      <select name="empleado_id" required>
        <option value="">--</option>
        <% empleados.forEach(e => { %>
          <option value="<%= e._id %>" <%= asignacion.empleado_id && asignacion.empleado_id.toString() === e._id.toString() ? 'selected' : '' %>><%= e.nombre + ' ' + e.apellido %></option>
        <% }) %>
      </select>
    </label><br>
    <label>Observaciones: <input name="observaciones" value="<%= asignacion.observaciones || '' %>" required></label><br>
    <button type="submit">Guardar</button>
  </form>
  <a href="/asignaciones/vista">Cancelar</a>
  <script>
    const toggle = document.getElementById('theme-toggle');
    const body = document.body;

    if (localStorage.getItem('theme') === 'dark') {
      body.classList.add('dark');
      toggle.textContent = '☀️';
    }

    toggle.addEventListener('click', () => {
      body.classList.toggle('dark');
      const isDark = body.classList.contains('dark');
      toggle.textContent = isDark ? '☀️' : '🌙';
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  </script>
</body>
</html>