<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title><%= categoria._id ? 'Editar' : 'Nueva' %> Categoría</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <a href="/" class="home-link">🏠 Inicio</a>
  <button class="theme-toggle" id="theme-toggle">🌙</button>
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success">
      <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
      <%= message || 'Operación exitosa' %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
      <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 9l-9 7z" fill="none"/><path d="M13.59 7.58L9 12.17 6.41 9.59 5 11l4 4 8-8z"/></svg>
      <%= message || 'Error en la operación' %>
    </div>
  <% } %>
  <h1><%= categoria._id ? 'Editar' : 'Crear' %> Categoría</h1>
  <form action="<%= categoria._id ? '/api/categorias/' + categoria._id + '?_method=PUT' : '/api/categorias' %>" method="post">
    <label>Nombre: <input name="nombre" value="<%= categoria.nombre || '' %>" required></label><br>
    <label>Descripción: <input name="descripcion" value="<%= categoria.descripcion || '' %>" required></label><br>
    <label>Código área: <input name="codigo_area" value="<%= categoria.codigo_area || '' %>" required></label><br>
    <label>Nivel prioridad: <input type="number" name="nivel_prioridad" value="<%= categoria.nivel_prioridad || 1 %>" required></label><br>
    <button type="submit">Guardar</button>
  </form>
  <a href="/categorias/vista">Cancelar</a>
  <script>
    const toggle = document.getElementById('theme-toggle');
    const body = document.body;

    if (localStorage.getItem('theme') === 'dark') {
      body.classList.add('dark');
      toggle.textContent = '☀️';
    }

    toggle.addEventListener('click', () => {
      body.classList.toggle('dark');
      const isDark = body.classList.contains('dark');
      toggle.textContent = isDark ? '☀️' : '🌙';
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  </script>
</body>
</html>